# =============================================================
# TruthGuard AI — Frontend Environment Variables
# =============================================================
# Copy this file to .env.local for local development.
# For deployment (Vercel, Netlify, Docker), set these as
# environment variables in your hosting dashboard.
# =============================================================

# URL of the deployed TruthGuard FastAPI backend.
# - Local dev:      http://localhost:8000  (auto-defaulted in code, no file needed)
# - Render/Railway: https://your-backend.onrender.com
# - Docker Compose: http://backend:8000
# - Custom domain:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://your-backend-url-here.com
